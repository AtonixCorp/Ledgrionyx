{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "ESNext"
        ],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "allowJs": false,
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": [
            "react",
            "react-native"
        ]
    },
    "include": [
        "index.js",
        "src/**/*"
    ]
}