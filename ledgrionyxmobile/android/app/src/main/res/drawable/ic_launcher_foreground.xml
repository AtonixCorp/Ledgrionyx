<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer — Ledgrionyx shield mark.

  Viewport: 108×108dp  (Android adaptive icon spec)
  Safe zone: central 72×72dp  (margin = 18dp each side)

  Coordinates are the original 64×64 SVG paths scaled by (72/64 = 1.125)
  and offset by 18dp so the mark lives entirely within the safe zone.

  Shield outer path:  M32,4  L52,12 V28 C52,43 43.4,54.2 32,60 ...
  Scale/offset rule:  x' = x*1.125 + 18 ,  y' = y*1.125 + 18
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body — same navy as background; visible only on light surfaces.
         On the navy background layer, only the gold ring + white A show. -->
    <path
        android:fillColor="#0A2A6C"
        android:pathData="M54,22.5 L76.5,31.5 V49.5
                          C76.5,66.4 67,79 54,85.5
                          C41,79 31.5,66.4 31.5,49.5
                          V31.5 Z"/>

    <!-- Gold inner border ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A44D"
        android:strokeWidth="2.8"
        android:pathData="M54,26.1 L73.1,33.6 V49.5
                          C73.1,63.8 65.1,74.9 54,81
                          C42.9,74.9 34.9,63.8 34.9,49.5
                          V33.6 Z"/>

</vector>
